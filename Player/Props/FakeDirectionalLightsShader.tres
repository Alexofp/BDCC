[gd_resource type="Shader" format=2]

[resource]
code = "shader_type spatial;
render_mode async_visible, blend_mix, depth_draw_opaque, cull_back, unshaded;

uniform vec4 albedo : hint_color;
uniform sampler2D texture_albedo : hint_albedo;
uniform vec3 uv1_scale;
uniform vec3 uv1_offset;

uniform vec3 light_direction_1 = vec3(0.0, -1.0, 0.0);
uniform vec4 light_color_1 : hint_color = vec4(1.0);
uniform float light_intensity_1 = 1.0;

uniform vec3 light_direction_2 = vec3(1.0, -1.0, 0.0);
uniform vec4 light_color_2 : hint_color = vec4(1.0);
uniform float light_intensity_2 = 1.0;

uniform vec4 ambient_color : hint_color = vec4(1.0, 1.0, 1.0, 1.0);
uniform float ambient_intensity = 0.1;

void vertex() {
    UV = UV * uv1_scale.xy + uv1_offset.xy;
}

void fragment() {
    vec2 base_uv = UV;
    vec4 albedo_tex = texture(texture_albedo, base_uv);
    vec3 base_color = albedo.rgb * albedo_tex.rgb;

    vec3 normal = normalize(NORMAL);

    vec3 light_dir_1 = normalize(
        (CAMERA_MATRIX * vec4(-light_direction_1, 0.0)).xyz
    );

    vec3 light_dir_2 = normalize(
        (CAMERA_MATRIX * vec4(-light_direction_2, 0.0)).xyz
    );

    float NdotL1 = max(dot(normal, light_dir_1), 0.0);
    float NdotL2 = max(dot(normal, light_dir_2), 0.0);

    vec3 diffuse1 =
        base_color *
        light_color_1.rgb *
        NdotL1 *
        light_intensity_1;

    vec3 diffuse2 =
        base_color *
        light_color_2.rgb *
        NdotL2 *
        light_intensity_2;

    vec3 ambient =
        base_color *
        ambient_color.rgb *
        ambient_intensity;

    ALBEDO = diffuse1 + diffuse2 + ambient;

    METALLIC = 0.0;
    ROUGHNESS = 1.0;
    SPECULAR = 0.5;
}"
